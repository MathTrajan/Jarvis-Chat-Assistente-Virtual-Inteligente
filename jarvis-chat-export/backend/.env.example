# Variáveis de ambiente do Jarvis Chat Backend
# Copie este arquivo para .env e preencha com suas chaves reais

# ─────────────────────────────────────────────
# Groq API Key
# Obtenha em: https://platform.groq.com/api-keys
# ─────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key_here

# ─────────────────────────────────────────────
# Google Gemini API Key
# Obtenha em: https://aistudio.google.com/app/apikey
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─────────────────────────────────────────────
# Configurações do Servidor
# ─────────────────────────────────────────────
PORT=3000

# ─────────────────────────────────────────────
# Estratégia de roteamento do agente
# Valores: "groq" | "gemini" | "auto"
# "auto" = tenta Groq primeiro, fallback para Gemini
# ─────────────────────────────────────────────
AGENT_ROUTING_STRATEGY=auto

# ─────────────────────────────────────────────
# Modelos utilizados (opcional - há defaults)
# ─────────────────────────────────────────────
GROQ_MODEL=llama3-8b-8192
GEMINI_MODEL=gemini-1.5-flash
